    },
    {
      "id": "evidence-001",
      "source": "CV",
      "text": "Led a small team to architected and deliver CustomerHub in a quarter (ahead of schedule), re-platforming a legacy .NET/Azure app into HubSpot CMS + React + Azure Functions, cutting deployment cycles by 75%.",
      "author": "Alex Bainbridge"
    },
    {
      "id": "evidence-001",
      "source": "CV",
      "text": "Created Clinithink’s first CI/CD pipeline using Terraform + Azure DevOps, cutting QA cycle times from days to hours.",
      "author": "Alex Bainbridge"
    },
    {
      "id": "evidence-001",
      "source": "CV",
      "text": "Built an employee portal using React, Node.js, MySQL, Liquibase, and Docker, deployed via Jenkins + Kubernetes + Helm.",
      "author": "Alex Bainbridge"
    },
    {
      "id": "evidence-001",
      "source": "CV",
      "text": "Built a distributed ETL framework in Python, integrating Kafka, Redis, Elasticsearch, and NiFi to automate data processing.",
      "author": "Alex Bainbridge"
    },
    {
      "id": "evidence-001",
