# --- Pipeline (data processing — run locally, not on Vercel) ---
OPENAI_API_KEY="YOUR_API_KEY_HERE"
LLM_DRY_RUN=false

# --- Frontend (Next.js — set these in Vercel project settings) ---
# PostHog analytics project API key (get from posthog.com → Project Settings → API Keys)
NEXT_PUBLIC_POSTHOG_KEY="phc_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# Production URL used for OG image metadata and sitemap generation
# Must include protocol, no trailing slash (e.g. https://yourdomain.com)
NEXT_PUBLIC_URL="https://yourdomain.com"
